<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f4f4f4"
    tools:context=".Doc.TermsConditions">

    <LinearLayout
        android:id="@+id/mainLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="16dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"
                    android:elevation="4dp"
                    app:cardCornerRadius="10dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/titleText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:text="Terms &amp; Conditions"
                            android:textColor="#212121"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/translateButton"
                            android:layout_width="60dp"
                            android:layout_height="40dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:backgroundTint="@color/teal_700"
                            android:text="H/E"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:elevation="4dp"
                    app:cardCornerRadius="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/lastUpdatedText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Last Updated: [ 25 JUNE 2025 ]"
                            android:textColor="#757575"
                            android:textSize="14sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/tcart1"
                    style="@style/TermsCardStyle">

                    <LinearLayout style="@style/TermsSectionLayout">

                        <TextView
                            style="@style/TermsHeading"
                            android:text="1. Introduction to the App" />

                        <TextView
                            style="@style/TermsContent"
                            android:text="MYNA is a monthly investment app that provides users with the opportunity to make monthly investments and offers returns based on the profit generated at the end of the month. This app functions like a fund manager." />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:id="@+id/tcart1h"
                    style="@style/TermsCardStyle">

                    <LinearLayout style="@style/TermsSectionLayout">

                        <TextView
                            style="@style/TermsHeading"
                            android:text="1. ऐप का परिचय" />

                        <TextView
                            style="@style/TermsContent"
                            android:text="MYNA एक मासिक निवेश ऐप है जो उपयोगकर्ताओं को मासिक निवेश करने का अवसर प्रदान करता है और माह के अंत में प्राप्त लाभ के अनुसार रिटर्न देता है। यह ऐप एक फंड मैनेजर की तरह कार्य करता है।" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/tcart2"
                    style="@style/TermsCardStyle">

                    <LinearLayout style="@style/TermsSectionLayout">

                        <TextView
                            style="@style/TermsHeading"
                            android:text="2. Investment Process" />

                        <TextView
                            style="@style/TermsContent"
                            android:text="The amount invested by the investor each month is deployed by the MYNA team across various sectors through a diversified investment strategy:\n\n• Fast-performing stocks for one month\n• Trading\n• Third-party services\n• Private or other funds\n\nAt the end of the month, after deducting 0.5% tax and 0.15% to 0.2% transfer charges from the profit earned, the remaining amount is sent to the user's account.\n\nFuture charges may increase. For detailed information, please refer to the 'Tax &amp; Charges Report'." />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:id="@+id/tcart2h"
                    style="@style/TermsCardStyle">

                    <LinearLayout style="@style/TermsSectionLayout">

                        <TextView
                            style="@style/TermsHeading"
                            android:text="2. निवेश प्रक्रिया" />

                        <TextView
                            style="@style/TermsContent"
                            android:text="निवेशकर्ता द्वारा हर महीने निवेश की गई राशि को MYNA टीम विविधीकृत निवेश रणनीति के माध्यम से विभिन्न क्षेत्रों में लगाती है:\n\n• एक माह के लिए तेज़ी से प्रदर्शन करने वाले स्टॉक्स\n• ट्रेडिंग\n• थर्ड पार्टी सेवाएँ\n• प्राइवेट या अन्य फंड्स\n\nमाह के अंत में, प्राप्त लाभ में से 0.5% टैक्स और 0.15% से 0.2% तक ट्रांसफर चार्ज काटकर शेष राशि उपयोगकर्ता को उनके खाते में भेजी जाती है।\n\nभविष्य में चार्ज की राशि बढ़ सकती है। विस्तृत जानकारी के लिए “टैक्स और शुल्क रिपोर्ट” देखें।" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/tcart3"
                    style="@style/TermsCardStyle">

                    <LinearLayout style="@style/TermsSectionLayout">

                        <TextView
                            style="@style/TermsHeading"
                            android:text="3. Risk Information" />

                        <TextView
                            style="@style/TermsContent"
                            android:text="• This investment is risky, and partial or complete loss is possible.\n• MYNA will not be responsible for any losses.\n• Investors are advised to invest at their own risk." />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:id="@+id/tcart3h"
                    style="@style/TermsCardStyle">

                    <LinearLayout style="@style/TermsSectionLayout">

                        <TextView
                            style="@style/TermsHeading"
                            android:text="3. जोखिम सूचना" />

                        <TextView
                            style="@style/TermsContent"
                            android:text="• यह निवेश जोखिमपूर्ण है, जिसमें आंशिक या पूर्ण हानि संभव है।\n• MYNA किसी भी नुकसान की भरपाई के लिए जिम्मेदार नहीं होगा।\n• निवेशकर्ता को सलाह दी जाती है कि वे अपने जोखिम पर निवेश करें।" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/tcart4"
                    style="@style/TermsCardStyle">

                    <LinearLayout style="@style/TermsSectionLayout">

                        <TextView
                            style="@style/TermsHeading"
                            android:text="4. Account Creation and Verification" />

                        <TextView
                            style="@style/TermsContent"
                            android:text="• To create an account, the user must provide an email, mobile number, password, Aadhaar card, PAN card, and bank details.\n• In the future, Google or other login services will be used.\n• User information is stored in Firebase Authentication and a secure database." />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:id="@+id/tcart4h"
                    style="@style/TermsCardStyle">

                    <LinearLayout style="@style/TermsSectionLayout">

                        <TextView
                            style="@style/TermsHeading"
                            android:text="4. खाता निर्माण और सत्यापन" />

                        <TextView
                            style="@style/TermsContent"
                            android:text="• खाता बनाने के लिए उपयोगकर्ता को ईमेल, मोबाइल नंबर, पासवर्ड, आधार कार्ड, पैन कार्ड और बैंक विवरण देना आवश्यक है।\n• भविष्य में Google या अन्य लॉगिन सेवाओं का उपयोग किया जाएगा।\n• उपयोगकर्ता की जानकारी Firebase प्रमाणीकरण और सुरक्षित डेटाबेस में संग्रहित की जाती है।" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/tcart5"
                    style="@style/TermsCardStyle">

                    <LinearLayout style="@style/TermsSectionLayout">

                        <TextView
                            style="@style/TermsHeading"
                            android:text="5. Account Deletion" />

                        <TextView
                            style="@style/TermsContent"
                            android:text="To delete an account, the user must send an 'Account Delete Request' via email.\nSupport Email: myna.helpdesk@gmail.com" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:id="@+id/tcart5h"
                    style="@style/TermsCardStyle">

                    <LinearLayout style="@style/TermsSectionLayout">

                        <TextView
                            style="@style/TermsHeading"
                            android:text="5. खाता हटाना" />

                        <TextView
                            style="@style/TermsContent"
                            android:text="खाता हटाने के लिए उपयोगकर्ता को ईमेल द्वारा “अकाउंट डिलीट रिक्वेस्ट” भेजनी होगी।\nसहायता ईमेल: myna.helpdesk@gmail.com" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/tcart6"
                    style="@style/TermsCardStyle">

                    <LinearLayout style="@style/TermsSectionLayout">

                        <TextView
                            style="@style/TermsHeading"
                            android:text="6. Refund Policy" />

                        <TextView
                            style="@style/TermsContent"
                            android:text="• If the user wishes to withdraw the amount before the end of the month, sending an email is necessary.\n• Refunds may take 2-3 business days.\n• The amount will be refunded based on the profit/loss status at that time." />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:id="@+id/tcart6h"
                    style="@style/TermsCardStyle">

                    <LinearLayout style="@style/TermsSectionLayout">

                        <TextView
                            style="@style/TermsHeading"
                            android:text="6. धन वापसी नीति" />

                        <TextView
                            style="@style/TermsContent"
                            android:text="• यदि उपयोगकर्ता माह के अंत से पहले राशि वापस चाहता है, तो ईमेल भेजना आवश्यक है।\n• वापसी में 2-3 कार्यदिवस लग सकते हैं।\n• उस समय लाभ/हानि की स्थिति के आधार पर ही राशि वापस की जाएगी।" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/tcart7"
                    style="@style/TermsCardStyle">

                    <LinearLayout style="@style/TermsSectionLayout">

                        <TextView
                            style="@style/TermsHeading"
                            android:text="7. Data and Privacy" />

                        <TextView
                            style="@style/TermsContent"
                            android:text="The app collects the following user information:\n• Name, Email, Mobile Number\n• Bank Details\n• Aadhaar and PAN Details\n\nThis information is shared only with trusted and authorized third-party services." />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:id="@+id/tcart7h"
                    style="@style/TermsCardStyle">

                    <LinearLayout style="@style/TermsSectionLayout">

                        <TextView
                            style="@style/TermsHeading"
                            android:text="7. डेटा और गोपनीयता" />

                        <TextView
                            style="@style/TermsContent"
                            android:text="ऐप उपयोगकर्ता की निम्न जानकारी एकत्र करता है:\n• नाम, ईमेल, मोबाइल नंबर\n• बैंक विवरण\n• आधार और पैन विवरण\n\nयह जानकारी केवल विश्वसनीय और अधिकृत थर्ड पार्टी सेवाओं के साथ साझा की जाती है।" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/tcart8"
                    style="@style/TermsCardStyle">

                    <LinearLayout style="@style/TermsSectionLayout">

                        <TextView
                            style="@style/TermsHeading"
                            android:text="8. Prohibited Activities" />

                        <TextView
                            style="@style/TermsContent"
                            android:text="• MYNA does not display any advertisements.\n• Does not track user activity.\n• Any illegal or government regulation-violating activity is not supported in the app." />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:id="@+id/tcart8h"
                    style="@style/TermsCardStyle">

                    <LinearLayout style="@style/TermsSectionLayout">

                        <TextView
                            style="@style/TermsHeading"
                            android:text="8. निषिद्ध गतिविधियाँ" />

                        <TextView
                            style="@style/TermsContent"
                            android:text="• MYNA कोई विज्ञापन नहीं दिखाता।\n• उपयोगकर्ता की ट्रैकिंग नहीं करता।\n• कोई भी अवैध या सरकारी नियमों के विरुद्ध गतिविधि ऐप में समर्थित नहीं है।" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/tcart9"

                    style="@style/TermsCardStyle">

                    <LinearLayout style="@style/TermsSectionLayout">

                        <TextView
                            style="@style/TermsHeading"
                            android:text="9. Legal Compliance &amp; Jurisdiction" />

                        <TextView
                            style="@style/TermsContent"
                            android:text="We operate in accordance with Indian law and are subject to the jurisdiction of Indian courts in case of any dispute." />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <androidx.cardview.widget.CardView
                    android:id="@+id/tcart9h"
                    style="@style/TermsCardStyle">

                    <LinearLayout style="@style/TermsSectionLayout">

                        <TextView
                            style="@style/TermsHeading"
                            android:text="9. कानूनी अनुपालन एवं अधिकार क्षेत्र" />

                        <TextView
                            style="@style/TermsContent"
                            android:text="“हम भारतीय कानून के अनुसार कार्य करते हैं और किसी भी विवाद में भारत के न्यायालय के अधीन हैं।”" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>