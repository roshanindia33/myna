<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/card_background_white"> <TextView
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="Request Funds Withdrawal"
    android:textSize="22sp"
    android:textStyle="bold"
    android:textColor="@color/text_dark_primary"
    android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/tv_dialog_warning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Important: Please verify your bank account details are up-to-date. You can only withdraw the amount shown in your Invested Wallet."
        android:textColor="@color/error_red" android:textSize="14sp"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter Amount (e.g., 1000.00)"
        app:startIconDrawable="@drawable/withdraw_ic_rupee_black"
        app:startIconTint="@color/icon_dark_accent"
        app:boxCornerRadiusTopStart="10dp"
        app:boxCornerRadiusTopEnd="10dp"
        app:boxCornerRadiusBottomStart="10dp"
        app:boxCornerRadiusBottomEnd="10dp"
        app:boxStrokeColor="@color/text_accent_blue"
        app:hintTextColor="@color/text_dark_secondary"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_withdrawal_amount_dialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:maxLength="10"
            android:textColor="@color/text_dark_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>