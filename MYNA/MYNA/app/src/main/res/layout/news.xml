<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bankaccount_background_gradient_light_blue_purple"
    tools:context=".userdata.News">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <!-- Gradient Header Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="30dp"
                    android:background="@drawable/userporfolio_header_gradient_teal_purple"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MYNA News Hub"
                        android:textColor="#FFFFFF"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stay Updated on App &amp; Investment Strategies"
                        android:textColor="#E0E0E0"
                        android:textSize="16sp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- News Card 1: Major App Update - Enhanced Analytics -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:backgroundTint="#FFFFFF"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="📈 Enhanced Analytics Dashboard Launched!"
                        android:textColor="#212121"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/news_item_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="4dp"
                        android:text="&lt;small&gt;&lt;i&gt;June 10, 2025&lt;/i&gt;&lt;/small&gt;&lt;br/&gt;&lt;br/&gt;We are thrilled to announce a major update to your MYNA app! Our new, highly intuitive analytics dashboard is now live. Get deeper insights into your investment performance with detailed charts, historical data, and personalized reports. Understand where your money is growing and how various strategies are performing over time. This update aims to provide you with unprecedented transparency and control over your financial journey. Explore the new dashboard today!"
                        android:textColor="#616161"
                        android:textSize="15sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- News Card 2: New Investment Strategy - Diversified Global Bonds -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🌍 Introducing Diversified Global Bonds Strategy"
                        android:textColor="#212121"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="&lt;small&gt;&lt;i&gt;June 05, 2025&lt;/i&gt;&lt;/small&gt;&lt;br/&gt;&lt;br/&gt;To further diversify your portfolio and enhance stability, MYNA is excited to launch our new Diversified Global Bonds investment strategy. This strategy focuses on investing in a mix of high-rated government and corporate bonds from stable economies worldwide. Designed for investors seeking moderate risk with consistent returns, this option provides an excellent balance to your existing equity-heavy portfolios. Speak to our team to learn how to integrate this strategy into your monthly investments."
                        android:textColor="#616161"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp"
                        android:id="@+id/news_item_2"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- News Card 3: Upcoming Feature - Direct Support Chat -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💬 Direct In-App Support Chat Coming Soon!"
                        android:textColor="#212121"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="&lt;small&gt;&lt;i&gt;May 28, 2025&lt;/i&gt;&lt;/small&gt;&lt;br/&gt;&lt;br/&gt;We heard you! Soon, you'll be able to chat directly with our support team right within the MYNA app. This new feature aims to provide you with even faster and more convenient assistance for all your queries. Say goodbye to emails for quick questions and get real-time help. Stay tuned for the official release date!"
                        android:textColor="#616161"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp"
                        android:id="@+id/news_item_3"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- News Card 4: Investment Tip - Diversify Your Portfolio -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="💡 Investment Tip: Diversify for Resilience"
                        android:textColor="#212121"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="&lt;small&gt;&lt;i&gt;May 20, 2025&lt;/i&gt;&lt;/small&gt;&lt;br/&gt;&lt;br/&gt;A key principle of smart investing is diversification. Don't put all your eggs in one basket! Spread your investments across different asset classes, industries, and geographies. This helps to mitigate risk and stabilize returns, even during market fluctuations. MYNA offers various strategies to help you achieve a well-diversified portfolio. Log in to explore how you can optimize your investments."
                        android:textColor="#616161"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp"
                        android:id="@+id/news_item_4"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- News Card 5: Upcoming Event/Webinar -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🗓️ Join Our Upcoming Investment Strategies Webinar!"
                        android:textColor="#212121"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="&lt;small&gt;&lt;i&gt;May 15, 2025&lt;/i&gt;&lt;/small&gt;&lt;br/&gt;&lt;br/&gt;Want to deepen your investment knowledge? Join us for an exclusive Monthly Investment Strategies. Our expert fund managers will share insights into upcoming market trends and how MYNA is adapting its strategies to maximize your returns. Spaces are limited, so register early within the app or through our website to secure your spot. Don't miss this opportunity to learn and grow! The Date will be announced soon!"
                        android:textColor="#616161"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp"
                        android:id="@+id/news_item_5"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="© 2025 MYNA "
                    android:textSize="14sp"
                    android:textColor="#555555" />

                <TextView
                    android:id="@+id/footer_privacy_policy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" | Privacy Policy"
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:textStyle="bold"
                    android:onClick="openPrivacyFromFooter" />

                <TextView
                    android:id="@+id/footer_terms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" | Terms"
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:textStyle="bold"
                    android:onClick="openTermsFromFooter" />

                <TextView
                    android:id="@+id/footer_support"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" | Support"
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:textStyle="bold"
                    android:onClick="openSupportFromFooter" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>