<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="10dp"
    app:cardBackgroundColor="@color/card_background_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirm Your Bank Details"
            android:textColor="@color/text_dark_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="15dp"
            android:gravity="center_horizontal"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Please review the details below carefully before confirming:"
            android:textColor="@color/text_medium_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="20dp"
            android:gravity="center_horizontal"/>

        <TextView
            android:id="@+id/dialogAccountHolderName"
            style="@style/DetailTextStyleDialog"
            android:text="Account Holder: "/>

        <TextView
            android:id="@+id/dialogAccountNumber"
            style="@style/DetailTextStyleDialog"
            android:text="Account Number: "/>

        <TextView
            android:id="@+id/dialogIfscCode"
            style="@style/DetailTextStyleDialog"
            android:text="IFSC Code: "/>

        <TextView
            android:id="@+id/dialogBankName"
            style="@style/DetailTextStyleDialog"
            android:text="Bank Name: "/>

        <TextView
            android:id="@+id/dialogBranch"
            style="@style/DetailTextStyleDialog"
            android:text="Branch: "/>

        <TextView
            android:id="@+id/dialogMobileNumber"
            style="@style/DetailTextStyleDialog"
            android:text="Mobile Number: "/>

        <TextView
            android:id="@+id/dialogUpiId"
            style="@style/DetailTextStyleDialog"
            android:text="UPI ID: "/>

        <TextView
            android:id="@+id/dialogPanNumber"
            style="@style/DetailTextStyleDialog"
            android:text="PAN Number: "/>

        <TextView
            android:id="@+id/dialogAadhaarNumber"
            style="@style/DetailTextStyleDialog"
            android:layout_marginBottom="25dp"
            android:text="Aadhaar Number: "/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/dialogEditButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Edit"
                android:background="@drawable/bankform_button_outline_grey"
                android:textColor="@color/text_medium_secondary"
                android:textStyle="bold"
                android:paddingVertical="12dp"
                android:layout_marginEnd="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"/>

            <Button
                android:id="@+id/dialogConfirmButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Confirm"
                android:background="@drawable/bankform_button_gradient_blue"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:paddingVertical="12dp"
                android:layout_marginStart="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>