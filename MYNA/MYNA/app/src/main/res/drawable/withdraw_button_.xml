<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background Color -->
    <solid android:color="@color/teal_700" /> <!-- आप यहां कोई भी color दे सकते हैं -->

    <!-- Rounded Corners -->
    <corners android:radius="7dp" /> <!-- कोनों की गोलाई -->

    <!-- Optional Padding -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp" />
</shape>
